<!-- 页脚 -->
<footer id="footer">
    <div class="inner">

        <!-- 关于站点 -->
        <section>
            <h2>About</h2>
            <div>
                <%= theme.about_footer %>
            </div>
        </section>

        <!-- 社交链接图标 -->
        <section>
            <h2>Follow</h2>
            <ul class="icons">
                <% if (theme.twitter_url) { %>
                    <li>
                        <a href="<%= theme.twitter_url %>" class="icon style2 fa-twitter" target="_blank" rel="noopener noreferrer">
                            <span class="label">Twitter</span>
                        </a>
                    </li>
                <% } %>

                <% if (theme.telegram_url) { %>
                    <li>
                        <a href="<%= theme.telegram_url %>" class="icon style2 fa-paper-plane" target="_blank" rel="noopener noreferrer">
                            <span class="label">Telegram</span>
                        </a>
                    </li>
                <% } %>

                <% if (theme.comments_url) { %>
                    <li>
                        <a href="<%= theme.comments_url %>" class="icon style2 fa-comments" target="_blank" rel="noopener noreferrer">
                            <span class="label">Comments</span>
                        </a>
                    </li>
                <% } %>

                <% if (theme.alipay_url) { %>
                    <li>
                        <a href="<%= theme.alipay_url %>" class="icon style2 fa-alipay" target="_blank" rel="noopener noreferrer">
                            <span class="label">Alipay</span>
                        </a>
                    </li>
                <% } %>

                <% if (theme.facebook_url) { %>
                    <li>
                        <a href="<%= theme.facebook_url %>" class="icon style2 fa-facebook" target="_blank" rel="noopener noreferrer">
                            <span class="label">Facebook</span>
                        </a>
                    </li>
                <% } %>

                <% if (theme.instagram_url) { %>
                    <li>
                        <a href="<%= theme.instagram_url %>" class="icon style2 fa-instagram" target="_blank" rel="noopener noreferrer">
                            <span class="label">Instagram</span>
                        </a>
                    </li>
                <% } %>

                <% if (theme.dribble_url) { %>
                    <li>
                        <a href="<%= theme.dribble_url %>" class="icon style2 fa-dribbble" target="_blank" rel="noopener noreferrer">
                            <span class="label">Dribbble</span>
                        </a>
                    </li>
                <% } %>

                <% if (theme.github_url) { %>
                    <li>
                        <a href="<%= theme.github_url %>" class="icon style2 fa-github" target="_blank" rel="noopener noreferrer">
                            <span class="label">GitHub</span>
                        </a>
                    </li>
                <% } %>

                <% if (theme.googleplus_url) { %>
                    <li>
                        <a href="<%= theme.googleplus_url %>" class="icon style2 fa-google-plus" target="_blank" rel="noopener noreferrer">
                            <span class="label">Google+</span>
                        </a>
                    </li>
                <% } %>

                <% if (theme.behance_url) { %>
                    <li>
                        <a href="<%= theme.behance_url %>" class="icon style2 fa-behance" target="_blank" rel="noopener noreferrer">
                            <span class="label">Behance</span>
                        </a>
                    </li>
                <% } %>

                <% if (theme.fivehundredpx_url) { %>
                    <li>
                        <a href="<%= theme.fivehundredpx_url %>" class="icon style2 fa-500px" target="_blank" rel="noopener noreferrer">
                            <span class="label">500px</span>
                        </a>
                    </li>
                <% } %>

                <% if (theme.email_url) { %>
                    <li>
                        <a href="<%= theme.email_url %>" class="icon style2 fa-envelope-o" target="_blank" rel="noopener noreferrer">
                            <span class="label">Email</span>
                        </a>
                    </li>
                <% } %>

                <% if (theme.rss_url) { %>
                    <li>
                        <a href="<%= theme.rss_url %>" class="icon style2 fa-rss" target="_blank" rel="noopener noreferrer">
                            <span class="label">RSS</span>
                        </a>
                    </li>
                <% } %>
            </ul>
        </section>

        <!-- 版权信息 -->
        <ul class="copyright">
            <li>&copy; 八神鬼嗣  All rights reserved</li>
            <li>IPFS Links <a href="https://ywh865.github.io/" style="text-decoration:none; border-bottom:none;">ywh865.github.io</a></li>
        </ul>
    </div>
</footer>
