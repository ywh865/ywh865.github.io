<!-- 首页布局：展示首页大标题与文章卡片网格 -->

<!-- 首页头部 banner -->
<header>
    <!-- 主标题 -->
    <h1><%= theme.subtitle_main %></h1>
    <!-- 二级副标题 -->
    <p><%= theme.subtitle_secondary %></p>
</header>

<!-- 文章卡片网格 -->
<section class="tiles">
    <% page.posts.forEach(function(item, index){ %>
        <!-- 引入单个文章卡片片段，传入文章对象与索引（用于样式循环） -->
        <%- partial('_partial/article-index', {item: item, index: index}) %>
    <% }); %>
</section>

<!-- 分页导航 -->
<%- partial('_partial/pagination') %>
